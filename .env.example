# ============================================
# Nutri B2C Frontend — Environment Variables
# Copy to .env.local and fill in your values.
# Only NEXT_PUBLIC_* vars are exposed to the browser.
# ============================================

# --- App URL ---
# Used for password reset links, social sharing, OG meta
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- API Backend ---
# Server-side proxy target (used by next.config.mjs rewrites)
# Docker: http://backend:5000  |  Local: http://localhost:5000
API_BASE_URL=http://localhost:5000
# Optional: direct browser-to-API access (bypasses Next rewrites)
# NEXT_PUBLIC_API_BASE_URL=

# --- Appwrite (client-side auth) ---
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
# Legacy alias (either works):
# NEXT_PUBLIC_APPWRITE_PROJECT=

# --- Appwrite Database & Collections ---
NEXT_PUBLIC_APPWRITE_DATABASE_ID=nutrition_db
NEXT_PUBLIC_APPWRITE_PROFILES_COLLECTION_ID=profiles
NEXT_PUBLIC_APPWRITE_HEALTH_COLLECTION_ID=health_profiles

# --- Appwrite Teams ---
NEXT_PUBLIC_APPWRITE_ADMINS_TEAM_ID=

### Server-side only (private; DO NOT expose to browser) ###
APPWRITE_API_KEY=
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=
APPWRITE_DB_ID=nutrition_db
APPWRITE_PROFILES_COLLECTION_ID=profiles
APPWRITE_HEALTH_COLLECTION_ID=health_profiles
